    "list.activeSelectionBackground": "#33422A",
    "list.activeSelectionForeground": "#E4EAD6",
    "list.inactiveSelectionBackground": "#242B1E",
    "list.hoverBackground": "#242B1E",
    "list.highlightForeground": "#8FCB5C",

    "badge.background": "#8FCB5C",
    "badge.foreground": "#1C2118",

