    "extensionButton.prominentForeground": "#1C2118",

    "notificationCenterHeader.background": "#242B1E",
    "notifications.background": "#1C2118",
    "notifications.foreground": "#E4EAD6"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6B7A5E", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#8FCB5C" }
    },
    {
      "name": "Numbers and constants",
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#D9A441" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B48EE0" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#4FA9A4" }
    },
    {
      "name": "Classes and types",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#52C4C4" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#E4EAD6" }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#E2694A" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#E08A3E" }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation"],
      "settings": { "foreground": "#B8C4A8" }
    },
    {
      "name": "Markup headings",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#8FCB5C", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E08A3E", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#B48EE0", "fontStyle": "italic" }
    },
    {
      "name": "Markup links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#52C4C4" }
    }
  ]
}
