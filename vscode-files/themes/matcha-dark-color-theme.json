    "terminal.ansiRed": "#E2694A",
    "terminal.ansiGreen": "#8FCB5C",
    "terminal.ansiYellow": "#D9A441",
    "terminal.ansiBlue": "#4FA9A4",
    "terminal.ansiMagenta": "#B48EE0",
    "terminal.ansiCyan": "#52C4C4",
